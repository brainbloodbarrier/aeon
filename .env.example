# AEON Matrix Environment Configuration

# ═══════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL with pgvector) — REQUIRED
# ═══════════════════════════════════════════════════════════════
DB_PASSWORD=your_strong_password_here

# ═══════════════════════════════════════════════════════════════
# NEO4J (Optional - for relationship graphs)
# Start with: docker compose --profile graph up -d
# ═══════════════════════════════════════════════════════════════
NEO4J_PASSWORD=your_neo4j_password_here

# ═══════════════════════════════════════════════════════════════
# EMBEDDINGS (Optional - Docker Model Runner)
# Default: http://localhost:12434/engines/v1/embeddings
# Pull model: docker model pull hf.co/second-state/All-MiniLM-L6-v2-Embedding-GGUF
# Without this, memory retrieval falls back to importance+recency
# ═══════════════════════════════════════════════════════════════
# EMBEDDING_API_URL=http://localhost:12434/engines/v1/embeddings
